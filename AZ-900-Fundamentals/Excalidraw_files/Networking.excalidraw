    },
    {
      "id": "T35eTE1Haqs2WinMTb-jF",
      "type": "text",
      "x": 518.1475479920749,
      "y": 732.4803287739666,
      "width": 316.3898010253906,
      "height": 124.20631408691422,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1V",
      "roundness": null,
      "seed": 155015870,
      "version": 922,
      "versionNonce": 1999966654,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784087666630,
      "link": null,
      "locked": false,
      "text": "A computer hardware component\nthat connects a computer to a\ncomputer network.\n\nThey us Internet Protocol (IP).",
      "fontSize": 19.873010253906276,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A computer hardware component\nthat connects a computer to a\ncomputer network.\n\nThey us Internet Protocol (IP).",
      "autoResize": true,
      "lineHeight": 1.25
    },
