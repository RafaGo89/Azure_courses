      "boundElements": [],
      "updated": 1784087741350,
      "link": null,
      "locked": false,
      "text": "Azure Network\ninterfaces (NICs)",
      "fontSize": 34.14966692243306,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Azure Network\ninterfaces (NICs)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qmBn16djvn8dGMl2I-IX9",
      "type": "text",
      "x": -95.45727711776453,
      "y": 913.3516239763122,
      "width": 289.62493896484375,
      "height": 124.20631408691422,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Y",
      "roundness": null,
      "seed": 900846050,
      "version": 951,
      "versionNonce": 991840318,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784087841974,
      "link": null,
      "locked": false,
      "text": "Those are attached to VMs,\n Without a NIC, the VM would\nhave no way to communicate.\n\nA VM can have multiple NICs.",
      "fontSize": 19.873010253906276,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Those are attached to VMs,\n Without a NIC, the VM would\nhave no way to communicate.\n\nA VM can have multiple NICs.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "l5lbxHeJ3xn3jaMa4m4WK",
      "type": "text",
      "x": 1310.0629613998044,
      "y": 243.9638181586921,
      "width": 146.6986541748047,
      "height": 47.2222137451172,
      "angle": 0,
      "strokeColor": "#609825",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Z",
