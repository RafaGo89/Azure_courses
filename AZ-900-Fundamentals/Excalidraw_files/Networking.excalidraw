      "isDeleted": false,
      "boundElements": [],
      "updated": 1784087743634,
      "link": null,
      "locked": false,
      "text": "A software or hardware between\n2 pieces of equipment or protocol\nlayers in a computer network.",
      "fontSize": 19.873010253906276,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A software or hardware between\n2 pieces of equipment or protocol\nlayers in a computer network.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "jyJakQ2HRdsFQqRuLgxjI",
      "type": "text",
      "x": 499.2320742272931,
      "y": 630.3883302649682,
      "width": 341.39984130859375,
      "height": 85.37416730608265,
      "angle": 0,
