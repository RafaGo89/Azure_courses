      "isDeleted": false,
      "boundElements": [],
      "updated": 1784087627116,
      "link": null,
      "locked": false,
      "text": "Network Interfaces \nController (NIC)",
      "fontSize": 34.14966692243306,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Network Interfaces \nController (NIC)",
      "autoResize": true,
