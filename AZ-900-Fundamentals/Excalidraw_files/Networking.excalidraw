      "seed": 1584478526,
      "version": 172,
      "versionNonce": 79730210,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784087868352,
      "link": null,
      "locked": false,
      "text": "Subnets",
      "fontSize": 37.777770996093764,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Subnets",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "mNMdJRbtm-HjFZLKVVcN1",
      "type": "text",
      "x": 1238.6987748812837,
      "y": 308.8976992825528,
      "width": 264.05224609375,
      "height": 173.88883972167991,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1a",
      "roundness": null,
      "seed": 257683810,
      "version": 716,
      "versionNonce": 364864318,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784087944244,
      "link": null,
      "locked": false,
      "text": "It's a logical division of an\naddress space.\n\n--> These help you define\ndifferent kind of workloads\nand apply virtual isolation\nwithin your network.",
      "fontSize": 19.873010253906276,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It's a logical division of an\naddress space.\n\n--> These help you define\ndifferent kind of workloads\nand apply virtual isolation\nwithin your network.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "N-QSvXptYxX3iCU6N4HBg",
      "type": "text",
      "x": 1222.0254683707217,
      "y": 539.6913882231764,
      "width": 267.64874267578125,
      "height": 124.20631408691422,
      "angle": 0,
      "strokeColor": "#6741d9",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1b",
      "roundness": null,
      "seed": 1846870654,
      "version": 1035,
      "versionNonce": 574695458,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784088144764,
      "link": null,
      "locked": false,
      "text": "Azure has no concept of\nprivate and public subnets.\n  You have to configure the\nsubnet so it doesn't reach\nthe internet.",
      "fontSize": 19.873010253906276,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Azure has no concept of\nprivate and public subnets.\n  You have to configure the\nsubnet so it doesn't reach\nthe internet.",
      "autoResize": true,
      "lineHeight": 1.25
    },
