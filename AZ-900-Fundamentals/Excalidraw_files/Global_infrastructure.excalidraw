      "text": "Availability Zones (AZ)",
      "fontSize": 37.84407223542783,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Availability Zones (AZ)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "EqjkrfnnXXGisX3wb96zd",
      "type": "text",
      "x": 1693.2843770298998,
      "y": 438.85889364691536,
      "width": 486.58380126953125,
      "height": 245,
      "angle": 0,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0I",
      "roundness": null,
      "seed": 724737946,
      "version": 685,
      "versionNonce": 976089370,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783142323210,
      "link": null,
      "locked": false,
      "text": "It is a physical location made up of\none or more datacenters.\n\n--> A region generally contains\n3 Availability zones, those are\nisolated from each other, but\nclose enough for low-latency.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It is a physical location made up of\none or more datacenters.\n\n--> A region generally contains\n3 Availability zones, those are\nisolated from each other, but\nclose enough for low-latency.",
      "autoResize": true,
      "lineHeight": 1.25
    },
