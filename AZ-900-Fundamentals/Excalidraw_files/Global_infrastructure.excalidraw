      "lineHeight": 1.25
    },
    {
      "id": "V1BBmG9qyObGPX2bcax9D",
      "type": "text",
      "x": 49.90131354789901,
      "y": 664.9130196162287,
      "width": 449.5957946777344,
      "height": 385,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ao",
      "roundness": null,
      "seed": 1292490010,
      "version": 471,
      "versionNonce": 1740975238,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783140694503,
      "link": null,
      "locked": false,
      "text": "A geography is a discreet market\nof 2 or more regions that\npreservers data residency and\ncompliance boundaries.\n\nFor example:\nUnited States\nAzure Government (US)\nCanada\nBrazil\nMexico",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A geography is a discreet market\nof 2 or more regions that\npreservers data residency and\ncompliance boundaries.\n\nFor example:\nUnited States\nAzure Government (US)\nCanada\nBrazil\nMexico",
      "autoResize": true,
      "lineHeight": 1.25
    },
