      "isDeleted": false,
      "boundElements": [],
      "updated": 1783142451088,
      "link": null,
      "locked": false,
      "text": "--> Not every region has \nsupport for AZs.\n\nThese regions are known\nas Alternate or Other.\n\nRecommended regions\nare suppose to have\nat least 3 AZs\n",
      "fontSize": 28,
      "fontFamily": 5,
