      "link": null,
      "locked": false,
      "text": "A region is a grouping of\nmultiple Data Centers\n(Availability Zone).",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A region is a grouping of\nmultiple Data Centers\n(Availability Zone).",
