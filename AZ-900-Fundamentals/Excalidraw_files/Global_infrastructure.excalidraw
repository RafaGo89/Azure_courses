      "isDeleted": false,
      "boundElements": [],
      "updated": 1783142052591,
      "link": null,
      "locked": false,
      "text": "1. Foundational.\n2. Mainstream.\n3. Specialized.",
      "fontSize": 28,
      "fontFamily": 5,
