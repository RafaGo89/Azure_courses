    {
      "id": "QqLEbFFdJmY9GhYzUsmrJ",
      "type": "text",
      "x": -722.8654424848893,
      "y": 1190.9700823660644,
      "width": 400.2318115234375,
      "height": 245,
      "angle": 0,
      "strokeColor": "#a18072",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b08",
      "roundness": null,
      "seed": 2043392858,
      "version": 718,
      "versionNonce": 823157958,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783142070949,
      "link": null,
      "locked": false,
      "text": "A region that provides the\nbroadest range of service\ncapabilities.\n\n--> It is designed\nto support Availability Zones\nnor or in the future",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A region that provides the\nbroadest range of service\ncapabilities.\n\n--> It is designed\nto support Availability Zones\nnor or in the future",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "xNn2GhZYlpqKa9Kned01R",
      "type": "text",
      "x": -165.2025169532718,
      "y": 1122.9467454715896,
      "width": 378.82159423828125,
      "height": 40.273725196040886,
      "angle": 0,
      "strokeColor": "#15aabf",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b09",
      "roundness": null,
      "seed": 957806746,
      "version": 497,
      "versionNonce": 1685314566,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783142070949,
      "link": null,
      "locked": false,
      "text": "Alternate (other) region",
      "fontSize": 32.21898015683271,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Alternate (other) region",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "I-5pY3_a6MnjquBqCi9TF",
      "type": "text",
      "x": -220.69724510251183,
      "y": 1192.9714288516016,
      "width": 511.7557678222656,
      "height": 245,
      "angle": 0,
      "strokeColor": "#a18072",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0A",
      "roundness": null,
      "seed": 2007029082,
      "version": 955,
      "versionNonce": 1414405190,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783142098820,
      "link": null,
      "locked": false,
      "text": "A region that extends Azure's\nfootprint within a data residency\nboundary where a recommended region\nalso exists.\n\n--> Not designed to support \nAvailabilities Zones.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A region that extends Azure's\nfootprint within a data residency\nboundary where a recommended region\nalso exists.\n\n--> Not designed to support \nAvailabilities Zones.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "mqN294qpKhngyJ5-sXH5h",
      "type": "text",
      "x": -243.1919965192842,
      "y": 1668.0071609416682,
      "width": 287.44189453125,
      "height": 40.273725196040886,
      "angle": 0,
      "strokeColor": "#7950f2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0B",
      "roundness": null,
      "seed": 487497286,
      "version": 511,
      "versionNonce": 1851837914,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783141879931,
      "link": null,
      "locked": false,
      "text": "Service Availability",
      "fontSize": 32.21898015683271,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Service Availability",
      "autoResize": true,
