    },
    {
      "id": "dc0JPD6tWwz0FNbVtlwBp",
      "type": "text",
      "x": -317.96396863985905,
      "y": 1731.917603430292,
      "width": 562.1278686523438,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0C",
      "roundness": null,
      "seed": 1969484934,
      "version": 1139,
      "versionNonce": 1942403994,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783141951877,
      "link": null,
      "locked": false,
      "text": "--> General Availability (GA) is when\na service is considered ready to be used \npublicly by everyone.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "--> General Availability (GA) is when\na service is considered ready to be used \npublicly by everyone.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "d1WX0AKgssY8gtDzCOiaP",
      "type": "text",
      "x": -313.59172674745594,
      "y": 1893.1848038823086,
      "width": 470.25982666015625,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0D",
      "roundness": null,
      "seed": 279591110,
      "version": 1268,
      "versionNonce": 456178182,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783142032527,
      "link": null,
      "locked": false,
      "text": "3 categories for services in Azure,\ndetermines when cloud services\nbecome available:",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3 categories for services in Azure,\ndetermines when cloud services\nbecome available:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "P6GpY9WoQm85I8MjlZHVq",
      "type": "text",
      "x": -301.41302092548653,
      "y": 2018.2046790361373,
      "width": 212.3798828125,
      "height": 105,
      "angle": 0,
      "strokeColor": "#9c36b5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
