    {
      "id": "wYMkPlg7_9hEVwlAU4hVI",
      "type": "text",
      "x": 374.4108323620348,
      "y": 1182.1080266834085,
      "width": 489.15985107421875,
      "height": 280,
      "angle": 0,
      "strokeColor": "#a18072",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
