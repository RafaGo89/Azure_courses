      "seed": 1531168262,
      "version": 1241,
      "versionNonce": 1115899162,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783142177072,
      "link": null,
      "locked": false,
      "text": "Azure has specialized regions\nto meet compliance or legal reasons:\n\n1. US DoD central\n2. US Gov Virginia.\n3. US Gov Iowa.\n4. China East.\n5. China North",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Azure has specialized regions\nto meet compliance or legal reasons:\n\n1. US DoD central\n2. US Gov Virginia.\n3. US Gov Iowa.\n4. China East.\n5. China North",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "xxbYRDYlXR9MRgb8-uALG",
      "type": "text",
      "x": 1729.3642857288964,
      "y": 346.5375634045581,
      "width": 428.8027648925781,
      "height": 47.30509029428479,
