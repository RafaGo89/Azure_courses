        }
      ],
      "updated": 1783530526393,
      "link": null,
      "locked": false,
      "text": "It's a highly configurable server.\n\n--> Virtualization let you run a server\nwithout having to buy and maintain\nthe physical hardware that runs it.",
      "fontSize": 56.38264413745383,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It's a highly configurable server.\n\n--> Virtualization let you run a server\nwithout having to buy and maintain\nthe physical hardware that runs it.",
      "autoResize": true,
      "lineHeight": 1.25
    },
