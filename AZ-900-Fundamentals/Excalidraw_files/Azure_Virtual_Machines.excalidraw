      ],
      "updated": 1783535705941,
      "link": null,
      "locked": false,
      "text": "Stuff to consider:",
      "fontSize": 56.38264413745383,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Stuff to consider:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "RSebk1AUzSyv8RTMjgQk8",
      "type": "text",
      "x": 1851.1953662275137,
      "y": -407.7196470283105,
      "width": 792.5946044921875,
      "height": 211.43491551545185,
      "angle": 0,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a6",
      "roundness": null,
      "seed": 1052188059,
      "version": 691,
      "versionNonce": 1374494267,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783531232597,
      "link": null,
      "locked": false,
      "text": "--> The size of the virtual\nmachine is determined by the\nAzure image.",
      "fontSize": 56.38264413745383,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "--> The size of the virtual\nmachine is determined by the\nAzure image.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "zv3vGrQK67mjFZVWt-3sa",
      "type": "text",
      "x": 1839.4502568566495,
      "y": -127.14965346379552,
      "width": 855.0540771484375,
      "height": 211.43491551545185,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a7",
      "roundness": null,
      "seed": 2126417397,
      "version": 822,
      "versionNonce": 348364507,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783531232597,
      "link": null,
      "locked": false,
      "text": "--> The image defines the\ncombination of vCPUs, Memory,\nand Storage Capacity.",
      "fontSize": 56.38264413745383,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "--> The image defines the\ncombination of vCPUs, Memory,\nand Storage Capacity.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "R5HxFCojYnVn40B8B4gM2",
      "type": "text",
      "x": 2794.1433745601603,
      "y": -401.6394434031905,
      "width": 824.4053955078125,
      "height": 140.95661034363457,
      "angle": 0,
      "strokeColor": "#099268",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a8",
      "roundness": null,
      "seed": 1443654011,
      "version": 978,
      "versionNonce": 104926075,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783531232597,
      "link": null,
      "locked": false,
      "text": "--> Azure VMs are billed at an\nhourly rate.",
      "fontSize": 56.38264413745383,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "--> Azure VMs are billed at an\nhourly rate.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "_QO88scSJCuTXfipAp0ev",
      "type": "text",
      "x": 2824.405988045568,
      "y": -84.18899888833687,
      "width": 929.9189453125,
      "height": 140.95661034363457,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a9",
      "roundness": null,
      "seed": 1672582357,
      "version": 1036,
      "versionNonce": 178775067,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783531232597,
      "link": null,
      "locked": false,
      "text": "--> You can attach multiple\nManaged Disk to your Azure VMs.",
      "fontSize": 56.38264413745383,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "--> You can attach multiple\nManaged Disk to your Azure VMs.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "aKUNlOwQ6Z-NH8_LIhQBx",
      "type": "text",
      "x": 1563.93008780183,
      "y": 536.2082111926292,
      "width": 1004.4053955078125,
      "height": 281.91322068726913,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aA",
      "roundness": null,
      "seed": 832798363,
      "version": 681,
      "versionNonce": 1914535413,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783535844217,
      "link": null,
      "locked": false,
      "text": "When launching an Azure VM other\nnetworking components will be either\ncreated or associated to the\nVirtual Machine:",
      "fontSize": 56.38264413745383,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When launching an Azure VM other\nnetworking components will be either\ncreated or associated to the\nVirtual Machine:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5ZoNd77Iek8ayLNV7aPhb",
      "type": "text",
      "x": 790.170644324076,
      "y": 943.2138947343964,
      "width": 1068.0269775390625,
      "height": 211.43491551545185,
      "angle": 0,
      "strokeColor": "#6741d9",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aB",
      "roundness": null,
      "seed": 202180405,
      "version": 794,
      "versionNonce": 369358677,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783535844217,
      "link": null,
      "locked": false,
      "text": "--> Network Security Group (NSG):\nattached to the NIC, virtual firewall\nwith rules around ports and protocols.",
      "fontSize": 56.38264413745383,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "--> Network Security Group (NSG):\nattached to the NIC, virtual firewall\nwith rules around ports and protocols.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "UXKX6ufckhBVIY0qV3eSI",
      "type": "text",
      "x": 788.3583669013929,
      "y": 1264.566257226844,
      "width": 917.5946044921875,
      "height": 211.43491551545185,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aC",
      "roundness": null,
      "seed": 1991842005,
      "version": 977,
      "versionNonce": 1569998005,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783535844217,
      "link": null,
      "locked": false,
      "text": "--> Network Interface (NIC):\na device that handle ip protocols\nand networks communication.",
      "fontSize": 56.38264413745383,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "--> Network Interface (NIC):\na device that handle ip protocols\nand networks communication.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "vIFm-K_TXhvC-TLSB_7_W",
      "type": "text",
      "x": 2401.217959180015,
      "y": 977.8273959346407,
      "width": 828,
      "height": 140.95661034363457,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aD",
      "roundness": null,
      "seed": 1357563483,
      "version": 1120,
      "versionNonce": 1551099413,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783535844217,
      "link": null,
      "locked": false,
      "text": "--> Virtual Machines Instance:\nThe actual running server.",
      "fontSize": 56.38264413745383,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "--> Virtual Machines Instance:\nThe actual running server.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "oZ9hSgXfUlzBvQC4H2WQO",
      "type": "text",
      "x": 2390.1011787526263,
      "y": 1281.5731891882913,
      "width": 753.6486206054688,
      "height": 281.91322068726913,
      "angle": 0,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aE",
      "roundness": null,
      "seed": 1062059259,
      "version": 1246,
      "versionNonce": 362306421,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783535844217,
      "link": null,
      "locked": false,
      "text": "--> Public IP address:\nThe address that you\nwill use publicly access your\nVM.",
      "fontSize": 56.38264413745383,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "--> Public IP address:\nThe address that you\nwill use publicly access your\nVM.",
      "autoResize": true,
      "lineHeight": 1.25
    },
