      "updated": 1784050977806,
      "link": null,
      "locked": false,
      "text": "A load balancer associated with a Scale set\nwill allow to:\n\n--> Evenly distribute VMs across multiple AZs\nto make applications Highly Available.\n\n--> Use load balancer probe checks for more\nrobust Health checks.",
      "fontSize": 38.877756754557296,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A load balancer associated with a Scale set\nwill allow to:\n\n--> Evenly distribute VMs across multiple AZs\nto make applications Highly Available.\n\n--> Use load balancer probe checks for more\nrobust Health checks.",
      "autoResize": true,
      "lineHeight": 1.25
    },
