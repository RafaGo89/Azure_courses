      "updated": 1783833806161,
      "link": null,
      "locked": false,
      "text": "It's a feature that provides a fully\nisolated and dedicated environment for\nsecurely running App Service apps at\na high scale.\n\nIt's appropriate for workloads\nthat require:\n\n--> Very High Scale\n--> Isolation and secure network access\n--> High memory utilization",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It's a feature that provides a fully\nisolated and dedicated environment for\nsecurely running App Service apps at\na high scale.\n\nIt's appropriate for workloads\nthat require:\n\n--> Very High Scale\n--> Isolation and secure network access\n--> High memory utilization",
      "autoResize": true,
      "lineHeight": 1.25
    },
