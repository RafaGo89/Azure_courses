      "isDeleted": false,
      "boundElements": [],
      "updated": 1783832078649,
      "link": null,
      "locked": false,
      "text": "It's an HTTP-based service\nfor hosting web application,\nREST APIs and mobile back end.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It's an HTTP-based service\nfor hosting web application,\nREST APIs and mobile back end.",
